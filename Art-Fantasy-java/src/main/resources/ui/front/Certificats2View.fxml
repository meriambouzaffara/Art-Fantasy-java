<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f4f7fb;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.front.Certificats2Controller">

    <children>
        <Label text="🎓 Mes Certificats" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2d3436;" />

        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="Rechercher:" style="-fx-font-weight: bold;" />
            <TextField fx:id="searchField" promptText="Nom du certificat, cours ou participant..." HBox.hgrow="ALWAYS" />
            <Button text="🔄 Actualiser" onAction="#refresh" style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-cursor: hand;" />
        </HBox>

        <Label fx:id="lblInfo" style="-fx-text-fill: #636e72; -fx-font-size: 12;" />

        <TableView fx:id="certificatTable" prefHeight="500" style="-fx-background-radius: 10;">
            <columns>
                <TableColumn fx:id="colNom" text="Nom du certificat" prefWidth="200" />
                <TableColumn fx:id="colNiveau" text="Niveau" prefWidth="100" />
                <TableColumn fx:id="colScore" text="Score" prefWidth="80" />
                <TableColumn fx:id="colDate" text="Date d'obtention" prefWidth="120" />
                <TableColumn fx:id="colCours" text="Cours" prefWidth="200" />
                <TableColumn fx:id="colParticipant" text="Participant" prefWidth="200" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER">
            <Label style="-fx-text-fill: #888; -fx-font-size: 11;" text="💡 Les certificats sont générés automatiquement après validation d'un QCM" />
        </HBox>
    </children>
</VBox>