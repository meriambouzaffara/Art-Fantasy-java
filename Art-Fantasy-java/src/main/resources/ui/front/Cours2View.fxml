<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-background-color: #f4f7fb;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.front.Cours2Controller">
    <children>
        <Label text="🎨 Nos Formations Artistiques" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #2d3436; -fx-padding: 20 0 0 20;" />

        <ScrollPane fx:id="mainScroll" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <FlowPane fx:id="coursesGrid" hgap="25" vgap="25" prefWrapLength="1000">
                    <padding>
                        <Insets bottom="30" left="30" right="30" top="10" />
                    </padding>
                </FlowPane>
            </content>
        </ScrollPane>

        <VBox fx:id="detailView" visible="false" managed="false" spacing="15" style="-fx-padding: 30;">
            <Button text="← Retour aux cours" onAction="#retourListe" style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-cursor: hand;" />
            <Label fx:id="lblNom" style="-fx-font-size: 24; -fx-font-weight: bold;" />
            <Label fx:id="lblNiveau" style="-fx-text-fill: #636e72;" />
            <TextArea fx:id="taContenu" editable="false" wrapText="true" prefHeight="400" style="-fx-background-radius: 10;" />
            <Button text="📝 Passer le QCM" onAction="#goPasserQcm" style="-fx-background-color: #00b894; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;" />
        </VBox>
    </children>
</VBox>