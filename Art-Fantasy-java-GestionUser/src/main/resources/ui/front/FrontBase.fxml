<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1280.0" stylesheets="@../theme.css" styleClass="app-shell" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.front.FrontBaseController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="topbar">
            <padding>
                <Insets left="40.0" right="40.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <ImageView fitHeight="40.0" preserveRatio="true">
                    <Image url="@../logo.png" />
                </ImageView>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="10.0">
                <Button text="Accueil" mnemonicParsing="false" styleClass="navbar-link" onAction="#goHome" />
                <Button text="Événements" mnemonicParsing="false" styleClass="navbar-link" onAction="#goEvenements" />
                <MenuButton text="Cours" mnemonicParsing="false" styleClass="navbar-link">
                    <items>
                        <MenuItem text="Nos Cours" onAction="#goCours" />
                        <MenuItem text="Certificats" onAction="#goCertificats" />
                    </items>
                </MenuButton>
                <Button text="Magasin" mnemonicParsing="false" styleClass="navbar-link" onAction="#goMagasin" />
                <MenuButton text="Galerie" mnemonicParsing="false" styleClass="navbar-link">
                    <items>
                        <MenuItem text="Catégories" onAction="#goCategories" />
                        <MenuItem text="Oeuvres" onAction="#goOeuvres" />
                    </items>
                </MenuButton>
                <Button text="Avis &amp; Réclamations" mnemonicParsing="false" styleClass="navbar-link" onAction="#goAvis" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="12.0">
                <Button text="👑 Dashboard" mnemonicParsing="false" styleClass="btn-primary" onAction="#openDashboard" style="-fx-background-color: #c9a849; -fx-background-radius: 20; -fx-font-weight: bold;" />
                <Button text="Sign up" mnemonicParsing="false" styleClass="btn-primary" onAction="#signup" style="-fx-background-color: #241197; -fx-background-radius: 20; -fx-font-weight: bold;" />
                <Button text="Login" mnemonicParsing="false" styleClass="btn-secondary" onAction="#login" style="-fx-background-radius: 20; -fx-font-weight: bold; -fx-text-fill: #241197;" />
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="0.0" fillWidth="true">
            <VBox fx:id="heroSection" spacing="0.0" styleClass="hero-front" VBox.vgrow="ALWAYS" managed="true">
            </VBox>

            <VBox fx:id="contentHost" spacing="20.0" styleClass="content" VBox.vgrow="ALWAYS" managed="false" visible="false" />
        </VBox>
    </center>
</BorderPane>