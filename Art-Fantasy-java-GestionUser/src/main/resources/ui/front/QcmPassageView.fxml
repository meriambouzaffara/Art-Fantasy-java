<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f4f7fb;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.front.QcmPassageController">

    <children>
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Button text="← Retour aux cours" onAction="#handleRetour" style="-fx-background-color: #6c5ce7; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 8 15;" />
            <Label fx:id="lblTitreCours" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2d3436;" text="Chargement du cours..." />
        </HBox>

        <Label fx:id="lblInfo" style="-fx-text-fill: #888; -fx-font-size: 12;" text="" />

        <ScrollPane fitToWidth="true" prefHeight="500" style="-fx-background-color: transparent;">
            <content>
                <VBox fx:id="questionsContainer" spacing="20" style="-fx-padding: 10;" />
            </content>
        </ScrollPane>

        <HBox alignment="CENTER" spacing="20">
            <Button fx:id="btnValider" onAction="#handleValider" text="🎯 Valider mes réponses" style="-fx-background-color: #00b894; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand;" />
        </HBox>
    </children>
</VBox>