<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.back.OeuvreFormController" styleClass="surface" padding="20">
    <Label text="🖼️ Formulaire d'œuvre" styleClass="text-title" />
    
    <GridPane vgap="10.0" hgap="10.0">
        <columnConstraints>
            <ColumnConstraints minWidth="100" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <Label text="Titre:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="titreField" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        
        <Label text="Description:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextArea fx:id="descriptionField" GridPane.columnIndex="1" GridPane.rowIndex="1" prefRowCount="3" />
        
        <Label text="Prix:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="prixField" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        
        <Label text="Catégorie:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <ComboBox fx:id="categorieCombo" GridPane.columnIndex="1" GridPane.rowIndex="3" maxWidth="Infinity" />
        
        <Label text="Image:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <HBox spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
            <TextField fx:id="imageField" HBox.hgrow="ALWAYS" />
            <Button text="📁 Parcourir" onAction="#browseImage" styleClass="btn-secondary" />
        </HBox>
        
        <Label text="Artiste:" GridPane.columnIndex="0" GridPane.rowIndex="5" />
        <ComboBox fx:id="artisteCombo" GridPane.columnIndex="1" GridPane.rowIndex="5" maxWidth="Infinity" />
    </GridPane>
    
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#cancel" styleClass="btn-secondary" />
        <Button text="💾 Enregistrer" onAction="#save" styleClass="btn-primary" />
    </HBox>
</VBox>
