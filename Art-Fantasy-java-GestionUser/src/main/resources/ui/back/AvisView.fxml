<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.back.AvisController">
    <VBox spacing="4.0">
        <Label text="💬 Avis &amp; Réclamations" styleClass="text-title" />
        <Label text="Modérez les avis et répondez aux réclamations." styleClass="text-subtitle" />
    </VBox>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Rechercher..." prefWidth="200" />
        <ComboBox fx:id="typeFilter" promptText="Type" prefWidth="120" />
        <ComboBox fx:id="statutFilter" promptText="Statut" prefWidth="120" />
        <Button text="🔄 Rafraîchir" onAction="#refresh" styleClass="btn-secondary" />
        <HBox HBox.hgrow="ALWAYS" />
        <Button text="✏️ Répondre" onAction="#repondre" styleClass="btn-primary" />
        <Button text="🗑️ Supprimer" onAction="#deleteAvis" styleClass="btn-secondary" />
    </HBox>

    <TableView fx:id="avisTable" VBox.vgrow="ALWAYS" styleClass="surface">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50" />
            <TableColumn fx:id="colType" text="Type" prefWidth="100" />
            <TableColumn fx:id="colSujet" text="Sujet" prefWidth="200" />
            <TableColumn fx:id="colMessage" text="Message" prefWidth="300" />
            <TableColumn fx:id="colUtilisateur" text="Utilisateur" prefWidth="150" />
            <TableColumn fx:id="colDate" text="Date" prefWidth="120" />
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="100" />
        </columns>
    </TableView>
</VBox>
