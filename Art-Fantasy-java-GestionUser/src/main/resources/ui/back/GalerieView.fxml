<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.back.GalerieController">
    <VBox spacing="4.0">
        <Label text="🖼️ Gestion de la Galerie" styleClass="text-title" />
        <Label text="Gérez les œuvres d'art et leurs détails." styleClass="text-subtitle" />
    </VBox>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Rechercher une œuvre..." prefWidth="280" />
        <Button text="🔄 Rafraîchir" onAction="#refresh" styleClass="btn-secondary" />
        <HBox HBox.hgrow="ALWAYS" />
        <Button text="➕ Ajouter une œuvre" onAction="#addOeuvre" styleClass="btn-primary" />
        <Button text="✏️ Modifier" onAction="#editOeuvre" styleClass="btn-secondary" />
        <Button text="🗑️ Supprimer" onAction="#deleteOeuvre" styleClass="btn-secondary" />
    </HBox>

    <TableView fx:id="oeuvreTable" VBox.vgrow="ALWAYS" styleClass="surface">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50" />
            <TableColumn fx:id="colTitre" text="Titre" prefWidth="180" />
            <TableColumn fx:id="colDescription" text="Description" prefWidth="250" />
            <TableColumn fx:id="colPrix" text="Prix" prefWidth="100" />
            <TableColumn fx:id="colCategorie" text="Catégorie" prefWidth="120" />
            <TableColumn fx:id="colArtiste" text="Artiste" prefWidth="150" />
            <TableColumn fx:id="colStatus" text="Statut" prefWidth="100" />
        </columns>
    </TableView>
</VBox>
