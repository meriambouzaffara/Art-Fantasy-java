<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.back.MagasinController">
    <VBox spacing="4.0">
        <Label text="🖌️ Gestion du Magasin" styleClass="text-title" />
        <Label text="Gérez les articles et le stock." styleClass="text-subtitle" />
    </VBox>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Rechercher un article..." prefWidth="280" />
        <Button text="🔄 Rafraîchir" onAction="#refresh" styleClass="btn-secondary" />
        <HBox HBox.hgrow="ALWAYS" />
        <Button text="➕ Ajouter" onAction="#addArticle" styleClass="btn-primary" />
        <Button text="✏️ Modifier" onAction="#editArticle" styleClass="btn-secondary" />
        <Button text="🗑️ Supprimer" onAction="#deleteArticle" styleClass="btn-secondary" />
    </HBox>

    <TableView fx:id="articleTable" VBox.vgrow="ALWAYS" styleClass="surface">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50" />
            <TableColumn fx:id="colNom" text="Nom de l'article" prefWidth="200" />
            <TableColumn fx:id="colPrix" text="Prix" prefWidth="100" />
            <TableColumn fx:id="colQuantite" text="Quantité" prefWidth="90" />
            <TableColumn fx:id="colDescription" text="Description" prefWidth="250" />
            <TableColumn fx:id="colMagasin" text="Magasin" prefWidth="150" />
        </columns>
    </TableView>
</VBox>
