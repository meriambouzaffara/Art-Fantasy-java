<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox spacing="20" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.rouhfan.ui.back.CoursController"
      style="-fx-background-color: #f4f7f6;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <VBox spacing="16" HBox.hgrow="ALWAYS">
        <VBox spacing="4">
            <Label text="🎨 Gestion des Cours"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0f1c3f;" />
            <Label text="Gérez les formations et leurs contenus."
                   style="-fx-text-fill: #997953;" />
        </VBox>

        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="🔍 Rechercher un cours..." prefWidth="280" />
            <Button text="🔄" onAction="#refresh" />
            <HBox HBox.hgrow="ALWAYS" />
            <Button text="➕ Ajouter" onAction="#addCours"
                    style="-fx-background-color: #0f1c3f; -fx-text-fill: white;" />
            <Button text="✏️ Modifier" onAction="#editCours" />
            <Button text="⭐ Voir les notes" onAction="#handleVoirNotes"
                    style="-fx-background-color: #f6d365; -fx-text-fill: #0f1c3f; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 6; -fx-padding: 6 12;" />
            <Button text="⚡ Gérer le QCM (IA)" onAction="#handleGererQcm"
                    style="-fx-background-color: linear-gradient(to right, #4f46e5, #7c3aed);
                           -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;
                           -fx-background-radius: 6; -fx-padding: 6 12;" />
            <Button text="🗑️ Supprimer" onAction="#deleteCours"
                    style="-fx-background-color: #d94a3d; -fx-text-fill: white;" />
        </HBox>

        <TableView fx:id="coursTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNom"     text="Nom"     prefWidth="150"/>
                <TableColumn fx:id="colNiveau"  text="Niveau"  prefWidth="90"/>
                <TableColumn fx:id="colDuree"   text="Durée"   prefWidth="70"/>
                <TableColumn fx:id="colStatut"  text="Statut"  prefWidth="90"/>
                <TableColumn fx:id="colArtiste" text="Artiste" prefWidth="120"/>
            </columns>
        </TableView>
    </VBox>

    <VBox fx:id="formPane" spacing="15" prefWidth="500" visible="false" managed="false"
          style="-fx-background-color: #ffffff; -fx-background-radius: 12;
                 -fx-padding: 20;
                 -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);">

        <Label fx:id="lblFormTitre" text="➕ Ajouter un cours"
               style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f1c3f;" />

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color: transparent; -fx-background: white;">
            <VBox spacing="15">

                <VBox spacing="5">
                    <Label text="Nom *" style="-fx-font-weight: bold;" />
                    <TextField fx:id="tfNom" />
                    <Label fx:id="errNom" visible="false"
                           style="-fx-text-fill: #d94a3d; -fx-font-size: 11px;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Description" />
                    <TextArea fx:id="taDescription" prefHeight="60" wrapText="true" />
                </VBox>

                <HBox spacing="10">
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Niveau" />
                        <ComboBox fx:id="cbNiveau" maxWidth="Infinity" />
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Durée" />
                        <TextField fx:id="tfDuree" promptText="Ex: 2h 30m" />
                    </VBox>
                </HBox>

                <VBox spacing="5">
                    <Label text="Statut *" />
                    <ComboBox fx:id="cbStatut" maxWidth="Infinity" />
                </VBox>

                <VBox spacing="5">
                    <Label text="Contenu *" style="-fx-font-weight: bold;" />
                    <TextArea fx:id="taContenu" prefHeight="80" wrapText="true" />
                </VBox>

                <VBox spacing="5">
                    <Label text="Artiste *" />
                    <ComboBox fx:id="cbArtiste" maxWidth="Infinity" />
                </VBox>

                <VBox fx:id="questionsContainer" spacing="10"
                      visible="false" managed="false">
                    <Label text="📝 Questions du QCM"
                           style="-fx-font-weight: bold; -fx-text-fill: #0f1c3f;" />
                    <ListView fx:id="lvQuestions" prefHeight="100" />

                    <VBox spacing="8"
                          style="-fx-background-color: #f8f9fa; -fx-padding: 10;">
                        <TextArea fx:id="tfQuickQuestion"
                                  promptText="Texte de la question..."
                                  prefHeight="60" />

                        <GridPane hgap="5" vgap="5">
                            <TextField fx:id="tfQuickR1" promptText="R1"
                                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <CheckBox fx:id="cbR1"
                                      GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                            <TextField fx:id="tfQuickR2" promptText="R2"
                                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <CheckBox fx:id="cbR2"
                                      GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                            <TextField fx:id="tfQuickR3" promptText="R3"
                                       GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                            <CheckBox fx:id="cbR3"
                                      GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                            <TextField fx:id="tfQuickR4" promptText="R4"
                                       GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                            <CheckBox fx:id="cbR4"
                                      GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                        </GridPane>

                        <Button text="Ajouter la question"
                                onAction="#handleQuickAddQuestion"
                                maxWidth="Infinity" />
                    </VBox>
                </VBox>

            </VBox>
        </ScrollPane>

        <Label fx:id="lblErreurGlobal" text=""
               style="-fx-text-fill: #d94a3d;"/>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Annuler" onAction="#handleAnnuler"
                    style="-fx-background-color: #997953; -fx-text-fill: white;" />
            <Button fx:id="btnSauvegarder" text="Sauvegarder"
                    onAction="#handleSauvegarder"
                    style="-fx-background-color: #0f1c3f; -fx-text-fill: white;" />
        </HBox>
    </VBox>
</HBox>