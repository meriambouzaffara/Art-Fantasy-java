<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<VBox spacing="20.0" prefWidth="450.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.back.DetailsDialogController" styleClass="form-container" stylesheets="@oeuvres_categories.css">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <VBox spacing="5.0" alignment="CENTER">
        <Label fx:id="titleLabel" text="Détails" styleClass="text-title" />
        <Label fx:id="subtitleLabel" text="Informations complètes" styleClass="text-subtitle" />
    </VBox>

    <StackPane prefHeight="250.0" prefWidth="350.0" styleClass="image-preview-container">
        <ImageView fx:id="imageView" fitHeight="240.0" fitWidth="340.0" preserveRatio="true" />
    </StackPane>

    <VBox spacing="15.0" styleClass="surface" style="-fx-padding: 20; -fx-background-color: #f8fafc;">
        <VBox spacing="5.0">
            <Label text="NOM / TITRE" styleClass="filter-label" style="-fx-font-size: 11;" />
            <Label fx:id="nameLabel" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #241197;" wrapText="true" />
        </VBox>

        <VBox fx:id="extraInfoPane" spacing="12.0">
            <HBox spacing="20.0">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="PRIX" styleClass="filter-label" style="-fx-font-size: 11;" />
                    <Label fx:id="priceLabel" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #c9a849;" />
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="STATUT" styleClass="filter-label" style="-fx-font-size: 11;" />
                    <Label fx:id="statusLabel" styleClass="status-purple" style="-fx-font-size: 14;" />
                </VBox>
            </HBox>

            <VBox spacing="5.0">
                <Label text="CATÉGORIE" styleClass="filter-label" style="-fx-font-size: 11;" />
                <Label fx:id="categoryLabel" style="-fx-font-size: 14; -fx-text-fill: #2d1b4e;" />
            </VBox>

            <VBox spacing="5.0">
                <Label text="ARTISTE" styleClass="filter-label" style="-fx-font-size: 11;" />
                <Label fx:id="artistLabel" style="-fx-font-size: 14; -fx-text-fill: #2d1b4e;" />
            </VBox>

            <VBox spacing="5.0">
                <Label text="DESCRIPTION" styleClass="filter-label" style="-fx-font-size: 11;" />
                <Label fx:id="descriptionLabel" style="-fx-font-size: 13; -fx-text-fill: #5a4a72;" wrapText="true" />
            </VBox>
        </VBox>
    </VBox>

    <HBox alignment="CENTER">
        <Button text="Fermer" onAction="#close" styleClass="btn-close-details" />
    </HBox>
</VBox>
