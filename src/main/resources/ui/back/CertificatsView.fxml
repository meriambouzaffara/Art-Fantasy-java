<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.back.CertificatsController">
    <VBox spacing="4.0">
        <Label text="📜 Gestion des Certificats" styleClass="text-title" />
        <Label text="Gérez les certifications des participants." styleClass="text-subtitle" />
    </VBox>

    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Rechercher un certificat..." prefWidth="280" />
        <Button text="🔄 Rafraîchir" onAction="#refresh" styleClass="btn-secondary" />
        <HBox HBox.hgrow="ALWAYS" />
        <Button text="➕ Ajouter" onAction="#addCertificat" styleClass="btn-primary" />
        <Button text="✏️ Modifier" onAction="#editCertificat" styleClass="btn-secondary" />
        <Button text="🗑️ Supprimer" onAction="#deleteCertificat" styleClass="btn-secondary" />
    </HBox>

    <TableView fx:id="certificatTable" VBox.vgrow="ALWAYS" styleClass="surface">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50" />
            <TableColumn fx:id="colNom" text="Nom du certificat" prefWidth="200" />
            <TableColumn fx:id="colNiveau" text="Niveau" prefWidth="100" />
            <TableColumn fx:id="colScore" text="Score" prefWidth="80" />
            <TableColumn fx:id="colDate" text="Date d'obtention" prefWidth="140" />
            <TableColumn fx:id="colParticipant" text="Participant" prefWidth="150" />
            <TableColumn fx:id="colCours" text="Cours" prefWidth="150" />
        </columns>
    </TableView>
</VBox>
