<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.back.SponsorsController">
    <VBox spacing="4.0">
        <Label text="🤝 Gestion des Sponsors" styleClass="text-title" />
        <Label text="Gérez les sponsors et partenariats." styleClass="text-subtitle" />
    </VBox>

    <!-- TOP STATS -->
    <HBox spacing="20.0" alignment="CENTER">
        <VBox style="-fx-background-color: #fff3e0; -fx-padding: 15; -fx-background-radius: 10;" prefWidth="250" alignment="CENTER">
            <Label text="Total Sponsors" style="-fx-text-fill: #f57c00; -fx-font-weight: bold;" />
            <Label fx:id="statTotalSponsors" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #f57c00;" />
        </VBox>
        <VBox style="-fx-background-color: #e0f7fa; -fx-padding: 15; -fx-background-radius: 10;" prefWidth="250" alignment="CENTER">
            <Label text="Nouveaux Sponsors (30j)" style="-fx-text-fill: #0097a7; -fx-font-weight: bold;" />
            <Label fx:id="statRecentSponsors" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0097a7;" />
        </VBox>
    </HBox>

    <!-- TOP Row: Search and Buttons -->
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Rechercher un sponsor..." prefWidth="280" />
        <Label text="Tri:" />
        <ComboBox fx:id="sortCombo" prefWidth="150" />
        <Button text="🔄 Rafraîchir" onAction="#refresh" styleClass="btn-secondary" />
        <HBox HBox.hgrow="ALWAYS" />
        <Button text="➕ Ajouter" onAction="#addSponsor" styleClass="btn-primary" />
        <Button text="✏️ Modifier" onAction="#editSponsor" styleClass="btn-secondary" />
        <Button text="🗑️ Supprimer" onAction="#deleteSponsor" styleClass="btn-secondary" />
    </HBox>

    <!-- Table -->
    <TableView fx:id="sponsorTable" VBox.vgrow="ALWAYS" styleClass="surface">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50" />
            <TableColumn fx:id="colNom" text="Nom" prefWidth="180" />
            <TableColumn fx:id="colEmail" text="Email" prefWidth="200" />
            <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="120" />
            <TableColumn fx:id="colAdresse" text="Adresse" prefWidth="180" />
            <TableColumn fx:id="colDate" text="Date de partenariat" prefWidth="150" />
        </columns>
    </TableView>
</VBox>

