<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.ScrollPane?>

<VBox spacing="14.0"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.rouhfan.ui.back.EvenementsController"
      styleClass="content"
      stylesheets="@oeuvres_categories.css">

    <VBox spacing="4.0">
        <Label text="📅 Gestion des Événements" styleClass="text-title"/>
        <Label text="Planifiez et gérez les événements artistiques." styleClass="text-subtitle"/>
    </VBox>

    <HBox spacing="20.0" alignment="CENTER">
        <VBox style="-fx-background-color: #fce4ec; -fx-padding: 10; -fx-background-radius: 10;" prefWidth="200" alignment="CENTER">
            <Label text="Total Événements" style="-fx-text-fill: #e91e63; -fx-font-weight: bold;"/>
            <Label fx:id="statTotalEvents" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #e91e63;"/>
        </VBox>

        <VBox style="-fx-background-color: #e3f2fd; -fx-padding: 10; -fx-background-radius: 10;" prefWidth="200" alignment="CENTER">
            <Label text="Capacité Totale" style="-fx-text-fill: #1976d2; -fx-font-weight: bold;"/>
            <Label fx:id="statTotalCapacity" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1976d2;"/>
        </VBox>

        <VBox style="-fx-background-color: #e8f5e9; -fx-padding: 10; -fx-background-radius: 10;" prefWidth="200" alignment="CENTER">
            <Label text="Participants Inscrits" style="-fx-text-fill: #388e3c; -fx-font-weight: bold;"/>
            <Label fx:id="statTotalParticipants" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #388e3c;"/>
        </VBox>
    </HBox>

    <!-- Recherche + Tri -->
    <HBox spacing="15.0" alignment="CENTER_LEFT" styleClass="surface" style="-fx-padding: 5;">
        <TextField fx:id="searchField" promptText="🔍 Rechercher un événement..." prefWidth="280" styleClass="text-field"/>
        <Label text="Tri:" styleClass="filter-label"/>
        <ComboBox fx:id="sortCombo" prefWidth="180" styleClass="combo-box"/>
        <Button text="🔄Rafraîchir" onAction="#refresh" styleClass="btn-search"/>
        <HBox HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Actions -->
    <HBox spacing="15.0" alignment="CENTER_RIGHT" styleClass="surface" style="-fx-padding: 5;">
        <Button text="📅Agenda" onAction="#openGoogleCalendar" styleClass="btn-view-reflet"/>

        <Button onAction="#addEvenement" styleClass="btn-add">
            <graphic>
                <HBox alignment="CENTER" spacing="8.0">
                    <Label text="+" styleClass="btn-add-icon"/>
                    <Label text="Ajouter"/>
                </HBox>
            </graphic>
        </Button>

        <Button text="✏️Modifier" onAction="#editEvenement" styleClass="btn-edit-reflet"/>
        <Button text="🗑️Supprimer" onAction="#deleteEvenement" styleClass="btn-delete-reflet"/>
    </HBox>

    <!-- Tabs -->
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" styleClass="tab-pane">
        <tabs>

            <!-- Liste -->
            <Tab text="📋 Liste des Événements">
                <VBox>
                    <TableView fx:id="evenementTable" VBox.vgrow="ALWAYS" styleClass="table-art-fantasy">
                        <columns>
                            <TableColumn fx:id="colTitre" text="Titre" prefWidth="180"/>
                            <TableColumn fx:id="colDate" text="Date" prefWidth="120"/>
                            <TableColumn fx:id="colLieu" text="Lieu" prefWidth="150"/>
                            <TableColumn fx:id="colSponsor" text="Sponsor" prefWidth="120"/>
                            <TableColumn fx:id="colType" text="Type" prefWidth="100"/>
                            <TableColumn fx:id="colCapacite" text="Capacité" prefWidth="80"/>
                            <TableColumn fx:id="colNbParticipants" text="Participants" prefWidth="90"/>
                            <TableColumn fx:id="colStatut" text="Statut" prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- Statistiques -->
            <Tab text="📊 Statistiques (Par Type)">
                <VBox spacing="30.0" styleClass="surface" style="-fx-padding: 25;">
                    <HBox spacing="30.0" VBox.vgrow="ALWAYS">

                        <!-- Pie Chart -->
                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="Répartition par Type (Événements)" styleClass="text-title" style="-fx-font-size: 20;"/>

                            <StackPane alignment="CENTER">
                                <PieChart fx:id="typePieChart" prefHeight="350.0" legendSide="RIGHT"/>
                                <Circle radius="70.0" fill="WHITE"/>
                            </StackPane>
                        </VBox>

                        <!-- Bar Chart -->
                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="Participants par Type" styleClass="text-title" style="-fx-font-size: 20;"/>

                            <BarChart fx:id="participantsBarChart" prefHeight="350.0" legendVisible="false">
                                <xAxis>
                                    <CategoryAxis side="BOTTOM" label="Type"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis side="LEFT" label="Nb Participants"/>
                                </yAxis>
                            </BarChart>
                        </VBox>

                    </HBox>
                </VBox>
            </Tab>

            <!-- Calendrier Interne -->
            <Tab text="📅 Mon Calendrier">
                <VBox spacing="10.0" styleClass="surface" style="-fx-padding: 15;" VBox.vgrow="ALWAYS">
                    <!-- Navigation du calendrier -->
                    <HBox alignment="CENTER" spacing="20.0">
                        <Button text="◀ Précédent" onAction="#previousMonth" styleClass="btn-secondary"/>
                        <Label fx:id="monthYearLabel" text="Mois Année" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" prefWidth="250" alignment="CENTER"/>
                        <Button text="Suivant ▶" onAction="#nextMonth" styleClass="btn-secondary"/>
                    </HBox>

                    <!-- En-têtes des jours -->
                    <GridPane alignment="CENTER" hgap="5" vgap="5">
                        <Label text="Lun" GridPane.columnIndex="0" style="-fx-font-weight: bold; -fx-alignment: center;" prefWidth="120"/>
                        <Label text="Mar" GridPane.columnIndex="1" style="-fx-font-weight: bold; -fx-alignment: center;" prefWidth="120"/>
                        <Label text="Mer" GridPane.columnIndex="2" style="-fx-font-weight: bold; -fx-alignment: center;" prefWidth="120"/>
                        <Label text="Jeu" GridPane.columnIndex="3" style="-fx-font-weight: bold; -fx-alignment: center;" prefWidth="120"/>
                        <Label text="Ven" GridPane.columnIndex="4" style="-fx-font-weight: bold; -fx-alignment: center;" prefWidth="120"/>
                        <Label text="Sam" GridPane.columnIndex="5" style="-fx-font-weight: bold; -fx-alignment: center;" prefWidth="120"/>
                        <Label text="Dim" GridPane.columnIndex="6" style="-fx-font-weight: bold; -fx-alignment: center;" prefWidth="120"/>
                    </GridPane>

                    <!-- Grille du calendrier -->
                    <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
                        <GridPane fx:id="calendarGrid" hgap="5" vgap="5" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 5;">
                            <!-- Les jours seront générés dynamiquement par le contrôleur -->
                        </GridPane>
                    </ScrollPane>
                </VBox>
            </Tab>

        </tabs>
    </TabPane>

</VBox>