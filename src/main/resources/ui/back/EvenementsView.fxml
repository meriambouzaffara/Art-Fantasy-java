<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>



<VBox spacing="14.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.back.EvenementsController" styleClass="content" stylesheets="@oeuvres_categories.css">
    <VBox spacing="4.0">
        <Label text="📅 Gestion des Événements" styleClass="text-title" />
        <Label text="Planifiez et gérez les événements artistiques." styleClass="text-subtitle" />
    </VBox>
    <HBox spacing="20.0" alignment="CENTER">
        <VBox style="-fx-background-color: #fce4ec; -fx-padding: 15; -fx-background-radius: 10;" prefWidth="200" alignment="CENTER">
            <Label text="Total Événements" style="-fx-text-fill: #e91e63; -fx-font-weight: bold;" />
            <Label fx:id="statTotalEvents" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #e91e63;" />
        </VBox>

        <VBox style="-fx-background-color: #e3f2fd; -fx-padding: 15; -fx-background-radius: 10;" prefWidth="200" alignment="CENTER">
            <Label text="Capacité Totale" style="-fx-text-fill: #1976d2; -fx-font-weight: bold;" />
            <Label fx:id="statTotalCapacity" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1976d2;" />
        </VBox>

        <VBox style="-fx-background-color: #e8f5e9; -fx-padding: 15; -fx-background-radius: 10;" prefWidth="200" alignment="CENTER">
            <Label text="Participants Inscrits" style="-fx-text-fill: #388e3c; -fx-font-weight: bold;" />
            <Label fx:id="statTotalParticipants" text="0" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #388e3c;" />
        </VBox>
    </HBox>
    <!-- TOP Row 1: Recherche + Tri + Agenda -->
    <HBox spacing="15.0" alignment="CENTER_LEFT" styleClass="surface" style="-fx-padding: 10;">
        <TextField fx:id="searchField" promptText="🔍 Rechercher un événement..." prefWidth="280" styleClass="text-field" />

        <Label text="Tri:" styleClass="filter-label" />
        <ComboBox fx:id="sortCombo" prefWidth="180" styleClass="combo-box" />

        <Button text="🔄Rafraîchir" onAction="#refresh" styleClass="btn-search" />

        <HBox HBox.hgrow="ALWAYS" />

    </HBox>

    <!-- TOP Row 2: Actions -->
    <HBox spacing="15.0" alignment="CENTER_RIGHT" styleClass="surface" style="-fx-padding: 10;">
        <Button text="📅Agenda" onAction="#openGoogleCalendar" styleClass="btn-view-reflet" />
        <Button onAction="#addEvenement" styleClass="btn-add">
            <graphic>
                <HBox alignment="CENTER" spacing="8.0">
                    <Label text="+" styleClass="btn-add-icon" />
                    <Label text="Ajouter" />
                </HBox>
            </graphic>
        </Button>

        <Button text="✏️Modifier" onAction="#editEvenement" styleClass="btn-edit-reflet" />
        <Button text="🗑️Supprimer" onAction="#deleteEvenement" styleClass="btn-delete-reflet" />
    </HBox>
    <!-- Tabs Container -->
    <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" styleClass="tab-pane">
        <tabs>
            <Tab text="📋 Liste des Événements">
                <VBox>
                    <TableView fx:id="evenementTable" VBox.vgrow="ALWAYS" styleClass="table-art-fantasy">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                            <TableColumn fx:id="colTitre" text="Titre" prefWidth="180" />
                            <TableColumn fx:id="colDate" text="Date" prefWidth="120" />
                            <TableColumn fx:id="colLieu" text="Lieu" prefWidth="150" />
                            <TableColumn fx:id="colType" text="Type" prefWidth="100" />
                            <TableColumn fx:id="colCapacite" text="Capacité" prefWidth="80" />
                            <TableColumn fx:id="colStatut" text="Statut" prefWidth="100" />
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab text="📊 Statistiques (Par Type)">
                <VBox spacing="30.0" styleClass="surface" style="-fx-padding: 25;">
                    <HBox spacing="30.0" VBox.vgrow="ALWAYS">
                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="Répartition par Type (Événements)" styleClass="text-title" style="-fx-font-size: 20;" />
                            <StackPane>
                                <PieChart fx:id="typePieChart" prefHeight="350.0" legendSide="RIGHT" />
                                <javafx.scene.shape.Circle fill="WHITE" radius="70.0" />
                            </StackPane>
                        </VBox>
                        <VBox spacing="15.0" HBox.hgrow="ALWAYS" alignment="CENTER">
                            <Label text="Participants par Type" styleClass="text-title" style="-fx-font-size: 20;" />
                            <BarChart fx:id="participantsBarChart" prefHeight="350.0" legendVisible="false">
                                <xAxis>
                                    <CategoryAxis side="BOTTOM" label="Type" />
                                </xAxis>
                                <yAxis>
                                    <NumberAxis side="LEFT" label="Nb Participants" />
                                </yAxis>
                            </BarChart>
                        </VBox>
                    </HBox>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>
</VBox>

