<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.back.UtilisateursController">

    <!-- Header -->
    <VBox spacing="4.0">
        <Label text="👥 Gestion Des Utilisateurs" styleClass="text-title" />
        <Label text="Gérez les comptes utilisateurs et leurs accès." styleClass="text-subtitle" />
    </VBox>

    <!-- Statistiques -->
    <HBox spacing="14.0" alignment="CENTER_LEFT">
        <VBox spacing="2" alignment="CENTER" prefWidth="160" styleClass="stat-card"
              style="-fx-border-color: #241197;">
            <Label fx:id="statTotal" text="0" style="-fx-font-size: 30; -fx-font-weight: 800; -fx-text-fill: #241197;" />
            <Label text="Total" style="-fx-font-size: 12; -fx-text-fill: #5a4a72; -fx-font-weight: 600;" />
        </VBox>
        <VBox spacing="2" alignment="CENTER" prefWidth="160" styleClass="stat-card"
              style="-fx-border-color: #d63031;">
            <Label fx:id="statAdmins" text="0" style="-fx-font-size: 30; -fx-font-weight: 800; -fx-text-fill: #d63031;" />
            <Label text="👑 Admins" style="-fx-font-size: 12; -fx-text-fill: #5a4a72; -fx-font-weight: 600;" />
        </VBox>
        <VBox spacing="2" alignment="CENTER" prefWidth="160" styleClass="stat-card"
              style="-fx-border-color: #6c5ce7;">
            <Label fx:id="statArtistes" text="0" style="-fx-font-size: 30; -fx-font-weight: 800; -fx-text-fill: #6c5ce7;" />
            <Label text="🎨 Artistes" style="-fx-font-size: 12; -fx-text-fill: #5a4a72; -fx-font-weight: 600;" />
        </VBox>
        <VBox spacing="2" alignment="CENTER" prefWidth="160" styleClass="stat-card"
              style="-fx-border-color: #00b894;">
            <Label fx:id="statParticipants" text="0" style="-fx-font-size: 30; -fx-font-weight: 800; -fx-text-fill: #00b894;" />
            <Label text="🎭 Participants" style="-fx-font-size: 12; -fx-text-fill: #5a4a72; -fx-font-weight: 600;" />
        </VBox>
        <VBox spacing="2" alignment="CENTER" prefWidth="160" styleClass="stat-card"
              style="-fx-border-color: #0984e3;">
            <Label fx:id="statActifs" text="0" style="-fx-font-size: 30; -fx-font-weight: 800; -fx-text-fill: #0984e3;" />
            <Label text="✅ Actifs" style="-fx-font-size: 12; -fx-text-fill: #5a4a72; -fx-font-weight: 600;" />
        </VBox>
    </HBox>

    <!-- Barre d'outils : recherche + filtrage + actions -->
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Rechercher (nom, prénom, email)..." prefWidth="260" />
        <ComboBox fx:id="filterRoleCombo" promptText="Filtrer par rôle" prefWidth="170" />
        <ComboBox fx:id="filterStatutCombo" promptText="Filtrer par statut" prefWidth="160" />
        <Button text="🔄 Rafraîchir" onAction="#refresh" styleClass="btn-secondary" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="📤 Exporter CSV" onAction="#exportCSV" styleClass="btn-secondary" />
        <Button text="➕ Ajouter" onAction="#addUser" styleClass="btn-primary" />
        <Button text="✏️ Modifier" onAction="#editUser" styleClass="btn-secondary" />
        <Button text="🗑️ Supprimer" onAction="#deleteUser" style="-fx-background-color: #fee2e2; -fx-text-fill: #d63031; -fx-font-weight: 600; -fx-background-radius: 12; -fx-padding: 10 20; -fx-cursor: hand;" />
    </HBox>

    <!-- Tableau -->
    <TableView fx:id="userTable" VBox.vgrow="ALWAYS" styleClass="surface">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50" sortable="true" />
            <TableColumn fx:id="colNom" text="Nom" prefWidth="130" sortable="true" />
            <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="130" sortable="true" />
            <TableColumn fx:id="colEmail" text="Email" prefWidth="230" sortable="true" />
            <TableColumn fx:id="colRoles" text="Rôle" prefWidth="140" sortable="true" />
            <TableColumn fx:id="colStatut" text="Statut" prefWidth="100" sortable="true" />
            <TableColumn fx:id="colType" text="Type" prefWidth="100" sortable="true" />
            <TableColumn fx:id="colDate" text="Créé le" prefWidth="130" sortable="true" />
        </columns>
    </TableView>

    <!-- Barre de statut -->
    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 4 0 0 0;">
        <Label fx:id="statusLabel" text="Prêt" style="-fx-text-fill: #5a4a72; -fx-font-size: 12;" />
    </HBox>
</VBox>
