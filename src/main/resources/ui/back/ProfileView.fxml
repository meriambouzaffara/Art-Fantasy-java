<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.rouhfan.ui.back.ProfileController">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10" />
    </padding>

    <!-- Header -->
    <VBox spacing="4.0">
        <Label text="👤 Mon Profil" styleClass="text-title" />
        <Label text="Gérez vos informations personnelles et votre mot de passe." styleClass="text-subtitle" />
    </VBox>

    <!-- Informations en lecture seule -->
    <HBox spacing="20.0" alignment="CENTER_LEFT">
        <VBox spacing="4" style="-fx-background-color: #f0eef5; -fx-background-radius: 16; -fx-padding: 14 24;">
            <Label text="Rôle" style="-fx-font-size: 11; -fx-text-fill: #5a4a72; -fx-font-weight: 600;" />
            <Label fx:id="roleLabel" text="—" style="-fx-font-size: 15; -fx-text-fill: #241197; -fx-font-weight: 800;" />
        </VBox>
        <VBox spacing="4" style="-fx-background-color: #f0eef5; -fx-background-radius: 16; -fx-padding: 14 24;">
            <Label text="Statut" style="-fx-font-size: 11; -fx-text-fill: #5a4a72; -fx-font-weight: 600;" />
            <Label fx:id="statutLabel" text="—" style="-fx-font-size: 15; -fx-text-fill: #241197; -fx-font-weight: 800;" />
        </VBox>
        <VBox spacing="4" style="-fx-background-color: #f0eef5; -fx-background-radius: 16; -fx-padding: 14 24;">
            <Label text="Type" style="-fx-font-size: 11; -fx-text-fill: #5a4a72; -fx-font-weight: 600;" />
            <Label fx:id="typeLabel" text="—" style="-fx-font-size: 15; -fx-text-fill: #241197; -fx-font-weight: 800;" />
        </VBox>
        <VBox spacing="4" style="-fx-background-color: #f0eef5; -fx-background-radius: 16; -fx-padding: 14 24;">
            <Label text="Membre depuis" style="-fx-font-size: 11; -fx-text-fill: #5a4a72; -fx-font-weight: 600;" />
            <Label fx:id="dateCreationLabel" text="—" style="-fx-font-size: 15; -fx-text-fill: #241197; -fx-font-weight: 800;" />
        </VBox>
    </HBox>

    <!-- Section : Informations personnelles -->
    <VBox spacing="16" styleClass="surface" style="-fx-padding: 30; -fx-background-radius: 20;">
        <Label text="📝 Informations personnelles"
               style="-fx-font-size: 18; -fx-font-weight: 700; -fx-text-fill: #241197;" />

        <GridPane hgap="15" vgap="14">
            <columnConstraints>
                <ColumnConstraints minWidth="140" />
                <ColumnConstraints prefWidth="350" />
            </columnConstraints>

            <Label text="Nom" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="nomField" promptText="Votre nom"
                       style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 10; -fx-font-size: 13px;"
                       GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Prénom" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="prenomField" promptText="Votre prénom"
                       style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 10; -fx-font-size: 13px;"
                       GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Email" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="emailField" promptText="votre@email.com"
                       style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 10; -fx-font-size: 13px;"
                       GridPane.columnIndex="1" GridPane.rowIndex="2" />
        </GridPane>

        <Label fx:id="profileMessage" text="" wrapText="true" />

        <HBox alignment="CENTER_LEFT">
            <Button text="💾 Enregistrer les modifications" onAction="#handleSaveProfile"
                    style="-fx-background-color: linear-gradient(to right, #241197, #6c2a90); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 12; -fx-padding: 12 28; -fx-cursor: hand;" />
        </HBox>
    </VBox>

    <!-- Section : Changement de mot de passe -->
    <VBox spacing="16" styleClass="surface" style="-fx-padding: 30; -fx-background-radius: 20;">
        <Label text="🔒 Changer le mot de passe"
               style="-fx-font-size: 18; -fx-font-weight: 700; -fx-text-fill: #241197;" />

        <GridPane hgap="15" vgap="14">
            <columnConstraints>
                <ColumnConstraints minWidth="180" />
                <ColumnConstraints prefWidth="350" />
            </columnConstraints>

            <Label text="Mot de passe actuel" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <PasswordField fx:id="currentPasswordField" promptText="••••••••"
                           style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 10; -fx-font-size: 13px;"
                           GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Nouveau mot de passe" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <PasswordField fx:id="newPasswordField" promptText="Min. 6 caractères"
                           style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 10; -fx-font-size: 13px;"
                           GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Confirmer le mot de passe" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <PasswordField fx:id="confirmPasswordField" promptText="Confirmez le nouveau mot de passe"
                           style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 10; -fx-font-size: 13px;"
                           GridPane.columnIndex="1" GridPane.rowIndex="2" />
        </GridPane>

        <Label fx:id="passwordMessage" text="" wrapText="true" />

        <HBox alignment="CENTER_LEFT">
            <Button text="🔐 Modifier le mot de passe" onAction="#handleChangePassword"
                    style="-fx-background-color: linear-gradient(to right, #241197, #6c2a90); -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: 700; -fx-background-radius: 12; -fx-padding: 12 28; -fx-cursor: hand;" />
        </HBox>
    </VBox>
</VBox>
