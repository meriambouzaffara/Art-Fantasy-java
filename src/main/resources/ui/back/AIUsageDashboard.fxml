<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-width: 0;"
            xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.rouhfan.ui.back.AIUsageDashboardController">

<VBox spacing="25" style="-fx-padding: 10;">

    <!-- ═══════════════════════════════════════ -->
    <!--  Titre + Actions                        -->
    <!-- ═══════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="🤖 AI Usage &amp; Logs d'Activité"
               style="-fx-font-size: 26; -fx-font-weight: 800; -fx-text-fill: #241197;" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="🔄 Rafraîchir" onAction="#refreshDashboard" mnemonicParsing="false"
                style="-fx-background-color: #f0eef5; -fx-text-fill: #241197; -fx-background-radius: 20; -fx-font-weight: 700; -fx-padding: 8 20; -fx-cursor: hand;" />
        <Button text="📥 Exporter CSV" onAction="#exportLogsCSV" mnemonicParsing="false"
                style="-fx-background-color: linear-gradient(to right, #241197, #6c2a90); -fx-text-fill: white; -fx-background-radius: 20; -fx-font-weight: 700; -fx-padding: 8 20; -fx-cursor: hand;" />
    </HBox>

    <!-- ═══════════════════════════════════════ -->
    <!--  Statistiques IA (4 cartes)             -->
    <!-- ═══════════════════════════════════════ -->
    <GridPane hgap="20" vgap="20" alignment="CENTER">

        <!-- Appels API HuggingFace -->
        <VBox spacing="4" alignment="CENTER" prefWidth="230" prefHeight="120" GridPane.columnIndex="0" GridPane.rowIndex="0"
              style="-fx-background-color: linear-gradient(to bottom right, #241197, #6c2a90); -fx-background-radius: 16; -fx-padding: 20;">
            <Label fx:id="statApiCalls" text="0"
                   style="-fx-font-size: 36; -fx-font-weight: 800; -fx-text-fill: white;" />
            <Label text="🤖 Appels API IA"
                   style="-fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.8); -fx-font-weight: 600;" />
        </VBox>

        <!-- Erreurs API -->
        <VBox spacing="4" alignment="CENTER" prefWidth="230" prefHeight="120" GridPane.columnIndex="1" GridPane.rowIndex="0"
              style="-fx-background-color: linear-gradient(to bottom right, #e17055, #d63031); -fx-background-radius: 16; -fx-padding: 20;">
            <Label fx:id="statApiErrors" text="0"
                   style="-fx-font-size: 36; -fx-font-weight: 800; -fx-text-fill: white;" />
            <Label text="⚠️ Erreurs API"
                   style="-fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.8); -fx-font-weight: 600;" />
        </VBox>

        <!-- Total Logs -->
        <VBox spacing="4" alignment="CENTER" prefWidth="230" prefHeight="120" GridPane.columnIndex="2" GridPane.rowIndex="0"
              style="-fx-background-color: linear-gradient(to bottom right, #00b894, #00cec9); -fx-background-radius: 16; -fx-padding: 20;">
            <Label fx:id="statTotalLogs" text="0"
                   style="-fx-font-size: 36; -fx-font-weight: 800; -fx-text-fill: white;" />
            <Label text="📋 Total Logs"
                   style="-fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.8); -fx-font-weight: 600;" />
        </VBox>

        <!-- Total Erreurs -->
        <VBox spacing="4" alignment="CENTER" prefWidth="230" prefHeight="120" GridPane.columnIndex="3" GridPane.rowIndex="0"
              style="-fx-background-color: linear-gradient(to bottom right, #fdcb6e, #e67e22); -fx-background-radius: 16; -fx-padding: 20;">
            <Label fx:id="statTotalErrors" text="0"
                   style="-fx-font-size: 36; -fx-font-weight: 800; -fx-text-fill: white;" />
            <Label text="🔥 Total Erreurs"
                   style="-fx-font-size: 13; -fx-text-fill: rgba(255,255,255,0.8); -fx-font-weight: 600;" />
        </VBox>
    </GridPane>

    <!-- ═══════════════════════════════════════ -->
    <!--  Top Utilisateurs + Filtres             -->
    <!-- ═══════════════════════════════════════ -->
    <HBox spacing="20">
        <!-- Top utilisateurs actifs -->
        <VBox spacing="10" prefWidth="300"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(36, 17, 151, 0.08), 10, 0, 0, 4);">
            <Label text="🏆 Top Utilisateurs"
                   style="-fx-font-size: 16; -fx-font-weight: 800; -fx-text-fill: #241197;" />
            <VBox fx:id="topUsersContainer" spacing="5">
                <!-- Populated dynamically -->
            </VBox>
        </VBox>

        <!-- Filtres -->
        <VBox spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(36, 17, 151, 0.08), 10, 0, 0, 4);">
            <Label text="🔍 Filtres"
                   style="-fx-font-size: 16; -fx-font-weight: 800; -fx-text-fill: #241197;" />

            <HBox spacing="12" alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="Type d'action" style="-fx-font-size: 11; -fx-text-fill: #9b8fb5; -fx-font-weight: 600;" />
                    <ComboBox fx:id="filterActionType" prefWidth="180"
                              style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e8e4f0;" />
                </VBox>
                <VBox spacing="4">
                    <Label text="User ID" style="-fx-font-size: 11; -fx-text-fill: #9b8fb5; -fx-font-weight: 600;" />
                    <TextField fx:id="filterUserId" promptText="Ex: 5" prefWidth="100"
                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e8e4f0; -fx-padding: 6 10;" />
                </VBox>
                <VBox spacing="4">
                    <Label text="Date début" style="-fx-font-size: 11; -fx-text-fill: #9b8fb5; -fx-font-weight: 600;" />
                    <DatePicker fx:id="filterStartDate" prefWidth="140"
                                style="-fx-background-radius: 10;" />
                </VBox>
                <VBox spacing="4">
                    <Label text="Date fin" style="-fx-font-size: 11; -fx-text-fill: #9b8fb5; -fx-font-weight: 600;" />
                    <DatePicker fx:id="filterEndDate" prefWidth="140"
                                style="-fx-background-radius: 10;" />
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="🔎 Appliquer" onAction="#applyFilters" mnemonicParsing="false"
                        style="-fx-background-color: linear-gradient(to right, #241197, #6c2a90); -fx-text-fill: white; -fx-background-radius: 16; -fx-font-weight: 700; -fx-padding: 8 20; -fx-cursor: hand;" />
                <Button text="↩ Réinitialiser" onAction="#resetFilters" mnemonicParsing="false"
                        style="-fx-background-color: #f0eef5; -fx-text-fill: #241197; -fx-background-radius: 16; -fx-font-weight: 600; -fx-padding: 8 20; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </HBox>

    <!-- ═══════════════════════════════════════ -->
    <!--  Table des logs                         -->
    <!-- ═══════════════════════════════════════ -->
    <VBox spacing="10"
          style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(36, 17, 151, 0.08), 10, 0, 0, 4);">
        <Label text="📋 Logs d'Activité"
               style="-fx-font-size: 16; -fx-font-weight: 800; -fx-text-fill: #241197;" />

        <TableView fx:id="logsTable" prefHeight="400"
                   style="-fx-background-radius: 10; -fx-border-radius: 10;">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                <TableColumn fx:id="colDate" text="Date" prefWidth="160" />
                <TableColumn fx:id="colUserId" text="User ID" prefWidth="80" />
                <TableColumn fx:id="colAction" text="Action" prefWidth="180" />
                <TableColumn fx:id="colLevel" text="Niveau" prefWidth="80" />
                <TableColumn fx:id="colDetails" text="Détails" prefWidth="400" />
            </columns>
        </TableView>
    </VBox>

</VBox>
</ScrollPane>
