<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1280.0" stylesheets="@../theme.css" styleClass="app-shell" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.back.ArtisteBaseController">
    <left>
        <VBox spacing="0.0" styleClass="sidebar" prefWidth="280.0">
            <VBox spacing="10.0" style="-fx-padding: 0 0 30 0;">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <ImageView fitHeight="50.0" preserveRatio="true">
                        <Image url="@../logo.png" />
                    </ImageView>
                </HBox>
                <Label text="Dashboard Artiste" style="-fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 12;" />
            </VBox>

            <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                <Button fx:id="navAccueil" text="✨  Tableau de bord" mnemonicParsing="false" styleClass="sidebar-link" onAction="#openDashboardHome" maxWidth="Infinity" />
                <Region prefHeight="20" />

                <Label text="MES ESPACES" style="-fx-text-fill: #c9a849; -fx-font-size: 11; -fx-font-weight: 900; -fx-padding: 0 16 5 16; -fx-opacity: 0.9;" />
                <Button fx:id="navGalerie" text="🖼️  Mes Œuvres" mnemonicParsing="false" styleClass="sidebar-link" onAction="#openGalerie" maxWidth="Infinity" />
                <Button fx:id="navEvenements" text="📅  Mes Événements" mnemonicParsing="false" styleClass="sidebar-link" onAction="#openEvenements" maxWidth="Infinity" />
                <Button fx:id="navCours" text="🎨  Mes Cours" mnemonicParsing="false" styleClass="sidebar-link" onAction="#openCours" maxWidth="Infinity" />
                <Button fx:id="navCertificats" text="📜  Certificats" mnemonicParsing="false" styleClass="sidebar-link" onAction="#openCertificats" maxWidth="Infinity" />
                <Button fx:id="navFavoris" text="⭐  Mes Favoris" mnemonicParsing="false" styleClass="sidebar-link" onAction="#openFavoris" maxWidth="Infinity" />
            </VBox>

            <VBox spacing="10.0" style="-fx-padding: 20 0 0 0;">
                <Button text="← Retour au site" mnemonicParsing="false" styleClass="btn-sidebar-footer" onAction="#backToFront" maxWidth="Infinity" prefHeight="45" />
            </VBox>
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="topbar">
            <padding>
                <Insets left="30.0" right="30.0" />
            </padding>
            <Label fx:id="pageTitle" text="Tableau de bord" styleClass="text-title" style="-fx-font-size: 28; -fx-text-fill: #241197; -fx-font-weight: bold;" />

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER" spacing="15.0">
                <HBox alignment="CENTER" spacing="8.0" styleClass="surface" style="-fx-padding: 8 20; -fx-background-radius: 25; -fx-background-color: #f0f2f9;">
                    <Label text="🎨" style="-fx-font-size: 14;" />
                    <Label fx:id="userNameLabel" text="Artiste" style="-fx-font-weight: bold; -fx-text-fill: #241197;" />
                    <Label text="●" style="-fx-text-fill: #22c55e; -fx-font-size: 10;" />
                </HBox>
                <Button text="👤 Mon Profil" mnemonicParsing="false" styleClass="btn-secondary" onAction="#openProfile" style="-fx-background-radius: 25; -fx-padding: 8 20; -fx-font-weight: bold;" />
                <Button text="Se déconnecter" mnemonicParsing="false" styleClass="btn-secondary" onAction="#logout" style="-fx-background-radius: 25; -fx-padding: 8 20; -fx-font-weight: bold;" />
            </HBox>
        </HBox>
    </top>

    <center>
        <VBox spacing="20.0" styleClass="content">
            <VBox fx:id="contentHost" spacing="20.0" VBox.vgrow="ALWAYS" />
        </VBox>
    </center>
</BorderPane>