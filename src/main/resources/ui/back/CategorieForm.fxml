<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.back.CategorieFormController" styleClass="form-container" stylesheets="@oeuvres_categories.css,@../theme.css">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <VBox spacing="5.0">
        <Label fx:id="formTitle" text="🏷️ Nouvelle Catégorie" styleClass="text-title" />
        <Label text="Créez une catégorie pour organiser vos œuvres." styleClass="text-subtitle" />
    </VBox>
    
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background:transparent; -fx-background-color:transparent;">
        <VBox spacing="20.0">
            <VBox spacing="8.0">
                <Label text="Nom de la catégorie" styleClass="form-label" />
                <TextField fx:id="nomField" promptText="Ex: Peinture à l'huile" styleClass="form-control" />
                <Label fx:id="nomError" styleClass="error-label" managed="false" visible="false" />
            </VBox>

            <VBox spacing="15.0" alignment="TOP_CENTER">
                <Label text="Image de couverture" styleClass="form-label" alignment="CENTER_LEFT" maxWidth="Infinity" />
                <StackPane fx:id="imageContainer" prefHeight="240.0" prefWidth="240.0" styleClass="image-preview-container">
                    <ImageView fx:id="imagePreview" fitHeight="230.0" fitWidth="230.0" preserveRatio="true" smooth="true" cache="true" />
                    <Label fx:id="placeholderLabel" text="📷 Aperçu de l'image" style="-fx-text-fill: #94a3b8;" />
                </StackPane>
                <Button text="📁 Choisir une image" onAction="#browseImage" styleClass="btn-secondary" maxWidth="Infinity" />
                <Label fx:id="imageError" styleClass="error-label" managed="false" visible="false" />
            </VBox>
        </VBox>
    </ScrollPane>
    
    <HBox spacing="15.0" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#cancel" styleClass="btn-secondary" prefWidth="120" />
        <Button text="💾 Enregistrer" onAction="#save" styleClass="btn-primary" prefWidth="150" />
    </HBox>
</VBox>
