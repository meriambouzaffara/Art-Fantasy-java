<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootNode" spacing="40.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.back.DashboardHomeController" stylesheets="@oeuvres_categories.css">
    <VBox alignment="CENTER" spacing="10.0">
        <Label text="👑 Dashboard Admin" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #241197;" />
        <Label text="Gestion complète de la plateforme Rouh el Fann" styleClass="text-subtitle" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #6c2a90;" />
    </VBox>

    <GridPane hgap="25.0" vgap="25.0" alignment="CENTER">
        <VBox styleClass="dash-card" prefWidth="280.0" onMouseClicked="#openUtilisateurs" GridPane.columnIndex="0" GridPane.rowIndex="0">
            <Label text="👤" styleClass="dash-card-icon, color-users" />
            <Label text="Gestion Des Utilisateurs" styleClass="dash-card-title, color-users" />
            <Label text="Gestion des comptes" styleClass="dash-card-subtitle" />
        </VBox>
        <VBox styleClass="dash-card-featured" prefWidth="280.0" onMouseClicked="#openGalerie" GridPane.columnIndex="1" GridPane.rowIndex="0">
            <Label text="🖼️" styleClass="dash-card-icon, color-works" />
            <Label text="Œuvres" styleClass="dash-card-title, color-works" />
            <Label text="Galerie artistique" styleClass="dash-card-subtitle" />
        </VBox>
        <VBox styleClass="dash-card-featured" prefWidth="280.0" onMouseClicked="#openCategories" GridPane.columnIndex="2" GridPane.rowIndex="0">
            <Label text="🏷️" styleClass="dash-card-icon, color-categories" />
            <Label text="Catégories" styleClass="dash-card-title, color-categories" />
            <Label text="Organisation du contenu" styleClass="dash-card-subtitle" />
        </VBox>
        <VBox styleClass="dash-card" prefWidth="280.0" onMouseClicked="#openEvenements" GridPane.columnIndex="3" GridPane.rowIndex="0">
            <Label text="📅" styleClass="dash-card-icon, color-events" />
            <Label text="Événements" styleClass="dash-card-title, color-events" />
            <Label text="Programmation &amp; gestion" styleClass="dash-card-subtitle" />
        </VBox>

        <VBox styleClass="dash-card" prefWidth="280.0" onMouseClicked="#openSponsors" GridPane.columnIndex="0" GridPane.rowIndex="1">
            <Label text="🤝" styleClass="dash-card-icon, color-sponsors" />
            <Label text="Sponsors" styleClass="dash-card-title, color-sponsors" />
            <Label text="Partenaires officiels" styleClass="dash-card-subtitle" />
        </VBox>
        <VBox styleClass="dash-card" prefWidth="280.0" onMouseClicked="#openCours" GridPane.columnIndex="1" GridPane.rowIndex="1">
            <Label text="🎨" styleClass="dash-card-icon, color-courses" />
            <Label text="Cours" styleClass="dash-card-title, color-courses" />
            <Label text="Formations artistiques" styleClass="dash-card-subtitle" />
        </VBox>
        <VBox styleClass="dash-card" prefWidth="280.0" onMouseClicked="#openCertificats" GridPane.columnIndex="2" GridPane.rowIndex="1">
            <Label text="📜" styleClass="dash-card-icon, color-certificates" />
            <Label text="Certificats" styleClass="dash-card-title, color-certificates" />
            <Label text="Validation &amp; diplômes" styleClass="dash-card-subtitle" />
        </VBox>
        <VBox styleClass="dash-card" prefWidth="280.0" onMouseClicked="#openAvis" GridPane.columnIndex="3" GridPane.rowIndex="1">
            <Label text="💬" styleClass="dash-card-icon, color-avis" />
            <Label text="Avis &amp; Réclamations" styleClass="dash-card-title, color-avis" />
            <Label text="Gestion des retours" styleClass="dash-card-subtitle" />
        </VBox>

        <VBox styleClass="dash-card" prefWidth="280.0" onMouseClicked="#openMagasin" GridPane.columnIndex="0" GridPane.rowIndex="2">
            <Label text="🖌️" styleClass="dash-card-icon, color-stores" />
            <Label text="Magasins" styleClass="dash-card-title, color-stores" />
            <Label text="Gestion des points de vente" styleClass="dash-card-subtitle" />
        </VBox>
        <VBox styleClass="dash-card" prefWidth="280.0" onMouseClicked="#openArticles" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <Label text="📦" styleClass="dash-card-icon, color-articles" />
            <Label text="Articles" styleClass="dash-card-title, color-articles" />
            <Label text="Inventaire et produits" styleClass="dash-card-subtitle" />
        </VBox>
    </GridPane>
</VBox>
