<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="0.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.rouhfan.ui.front.FrontListeMagasinsController">

    <!-- Hero Banner Magasins -->
    <VBox alignment="CENTER" spacing="10.0"
          style="-fx-background-color: linear-gradient(to right, #241197, #6c2a90);
                 -fx-padding: 50 40 40 40;">
        <Label text="&#x1F3EA; Nos Magasins"
               style="-fx-font-size: 42; -fx-font-weight: 800; -fx-text-fill: white;" />
        <Label text="Explorez nos boutiques d'art fantasy et leurs collections exclusives"
               style="-fx-font-size: 16; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-style: italic;" />
        <Label fx:id="totalLabel" text="0 magasins disponibles"
               style="-fx-font-size: 13; -fx-text-fill: #c9a849; -fx-font-weight: bold;" />
    </VBox>

    <!-- Barre de recherche -->
    <HBox spacing="12.0" alignment="CENTER_LEFT"
          style="-fx-background-color: #f0eef5; -fx-padding: 16 30;
                 -fx-border-color: rgba(36,17,151,0.08); -fx-border-width: 0 0 1 0;">
        <Label text="&#x1F50D;" style="-fx-font-size: 16; -fx-text-fill: #241197;" />
        <TextField fx:id="searchField" promptText="Rechercher un magasin..." prefWidth="280"
                   onKeyReleased="#onSearch"
                   style="-fx-background-radius: 20; -fx-padding: 8 16; -fx-border-radius: 20;
                          -fx-border-color: rgba(36,17,151,0.15);" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="resultCount" text="" style="-fx-text-fill: #5a4a72; -fx-font-size: 13;" />
        <Button text="&#x2716; Effacer" onAction="#clearSearch"
                style="-fx-background-color: transparent; -fx-text-fill: #241197;
                       -fx-font-weight: bold; -fx-cursor: hand;" />
    </HBox>

    <!-- Grille de magasins scrollable -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background-color: #faf9fc; -fx-background: #faf9fc; -fx-border-color: transparent;">
        <VBox style="-fx-background-color: #faf9fc; -fx-padding: 30;">

            <!-- Message vide -->
            <VBox fx:id="emptyMessage" alignment="CENTER" spacing="15"
                  visible="false" managed="false"
                  style="-fx-padding: 60 0;">
                <Label text="&#x1F3EA;" style="-fx-font-size: 48;" />
                <Label text="Aucun magasin trouv&#233;"
                       style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #241197;" />
                <Label text="Essayez de modifier vos crit&#232;res de recherche."
                       style="-fx-font-size: 14; -fx-text-fill: #5a4a72;" />
            </VBox>

            <!-- FlowPane cartes magasins -->
            <FlowPane fx:id="magasinsFlow" hgap="20.0" vgap="20.0" prefWrapLength="900" />
        </VBox>
    </ScrollPane>

</VBox>
