<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.Image?>

<BorderPane prefWidth="900.0" prefHeight="650.0" stylesheets="@../theme.css" styleClass="app-shell"
            xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.rouhfan.ui.front.FaceLoginController">

    <!-- Top Bar -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="topbar">
            <padding><Insets left="30" right="30" /></padding>
            <ImageView fitHeight="35" preserveRatio="true">
                <Image url="@../logo.png" />
            </ImageView>
            <Label text="🔐 Connexion par Reconnaissance Faciale" style="-fx-font-size: 20; -fx-font-weight: 800; -fx-text-fill: #241197;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="← Retour au Login" onAction="#goBack" mnemonicParsing="false"
                    style="-fx-background-color: #f0eef5; -fx-text-fill: #241197; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 8 20; -fx-cursor: hand;" />
        </HBox>
    </top>

    <!-- Center Content -->
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">

            <!-- Camera Preview Card -->
            <VBox alignment="CENTER" spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 30;
                         -fx-effect: dropshadow(three-pass-box, rgba(36, 17, 151, 0.08), 20, 0, 0, 8);">

                <!-- Status -->
                <Label fx:id="statusLabel" text="⏳ Initialisation d'OpenCV..."
                       style="-fx-font-size: 15; -fx-font-weight: 700; -fx-text-fill: #5a4a72;" />

                <!-- Camera Preview -->
                <VBox alignment="CENTER"
                      style="-fx-background-color: #1a1a2e; -fx-background-radius: 16; -fx-padding: 4;">
                    <ImageView fx:id="cameraPreview" fitWidth="480" fitHeight="360" preserveRatio="true" />
                </VBox>

                <!-- Face Detection Status -->
                <Label fx:id="faceCountLabel" text=""
                       style="-fx-font-size: 14; -fx-font-weight: 700;" />

                <!-- Controls -->
                <HBox alignment="CENTER" spacing="12">
                    <Button fx:id="startCameraBtn" text="📷 Démarrer la caméra" onAction="#startCamera" mnemonicParsing="false"
                            style="-fx-background-color: linear-gradient(to right, #241197, #6c2a90); -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 12 28; -fx-cursor: hand;
                                   -fx-font-size: 14;" />
                    <Button fx:id="stopCameraBtn" text="⏹️ Arrêter" onAction="#stopCamera" mnemonicParsing="false"
                            style="-fx-background-color: #f0eef5; -fx-text-fill: #5a4a72;
                                   -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 12 28; -fx-cursor: hand;
                                   -fx-font-size: 14;" />
                    <Button fx:id="captureBtn" text="🔐 Scanner et Connexion" onAction="#captureAndLogin" mnemonicParsing="false"
                            style="-fx-background-color: linear-gradient(to right, #00b894, #00cec9); -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-background-radius: 25; -fx-padding: 12 28; -fx-cursor: hand;
                                   -fx-font-size: 14;" />
                </HBox>

                <!-- Result -->
                <VBox fx:id="resultBox" alignment="CENTER" spacing="5" visible="false">
                    <Label fx:id="resultLabel" text="" wrapText="true" />
                </VBox>
            </VBox>

            <!-- Instructions -->
            <HBox alignment="CENTER" spacing="30" style="-fx-padding: 10 0 0 0;">
                <VBox alignment="CENTER" spacing="4">
                    <Label text="1️⃣" style="-fx-font-size: 28;" />
                    <Label text="Démarrez la caméra" style="-fx-font-size: 12; -fx-text-fill: #5a4a72; -fx-font-weight: 600;" />
                </VBox>
                <Label text="→" style="-fx-font-size: 24; -fx-text-fill: #c9a849;" />
                <VBox alignment="CENTER" spacing="4">
                    <Label text="2️⃣" style="-fx-font-size: 28;" />
                    <Label text="Positionnez votre visage" style="-fx-font-size: 12; -fx-text-fill: #5a4a72; -fx-font-weight: 600;" />
                </VBox>
                <Label text="→" style="-fx-font-size: 24; -fx-text-fill: #c9a849;" />
                <VBox alignment="CENTER" spacing="4">
                    <Label text="3️⃣" style="-fx-font-size: 28;" />
                    <Label text="Cliquez sur Scanner" style="-fx-font-size: 12; -fx-text-fill: #5a4a72; -fx-font-weight: 600;" />
                </VBox>
            </HBox>

        </VBox>
    </center>
</BorderPane>
