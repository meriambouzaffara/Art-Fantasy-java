<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.front.EvenementsFrontController">
    <VBox spacing="4.0">
        <Label text="📅 Événements Artistiques" styleClass="text-title" />
        <Label text="Découvrez les événements à venir et participez aux expériences artistiques." styleClass="text-subtitle" />
    </VBox>

    <!-- TOP Row: Search and Buttons -->
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="🔍 Rechercher un événement..." prefWidth="280" />
        <Label text="Tri:" />
        <ComboBox fx:id="sortCombo" prefWidth="180" />
        <Button text="🔄 Rafraîchir" onAction="#refresh" styleClass="btn-secondary" />
        <Button fx:id="aiRecButton" text="✨ Recommandations IA" onAction="#showAiRecommendations" style="-fx-background-color: linear-gradient(to right, #6c2a90, #9b59b6); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;" visible="false" managed="false" />
        <HBox HBox.hgrow="ALWAYS" />
        <Button fx:id="addButton" text="➕ Ajouter Événement" onAction="#addEvenement" styleClass="btn-primary" visible="false" managed="false" />
    </HBox>

    <!-- Cards Container -->
    <ScrollPane fitToWidth="true" style="-fx-control-inner-background: transparent; -fx-padding: 0;">
        <FlowPane fx:id="cardsContainer" prefWidth="1000" prefHeight="600" hgap="20" vgap="20" style="-fx-padding: 15;" />
    </ScrollPane>
</VBox>
