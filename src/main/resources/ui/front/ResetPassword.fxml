<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="0" stylesheets="@../theme.css" styleClass="app-shell"
      prefHeight="800.0" prefWidth="1280.0"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.rouhfan.ui.front.ResetPasswordController">

    <!-- Top bar -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="topbar">
        <padding>
            <Insets left="40.0" right="40.0" />
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <ImageView fitHeight="40.0" preserveRatio="true">
                <Image url="@../logo.png" />
            </ImageView>
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <Region VBox.vgrow="ALWAYS" />

    <!-- Reset Password Card -->
    <VBox alignment="CENTER" spacing="20" maxWidth="440"
          style="-fx-background-color: #ffffff; -fx-background-radius: 24; -fx-padding: 50 40; -fx-effect: dropshadow(three-pass-box, rgba(36, 17, 151, 0.10), 20, 0, 0, 8);">

        <Label text="🔒" style="-fx-font-size: 48px;" />
        <Label text="Nouveau mot de passe" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #241197;" />
        <Label text="Choisissez un nouveau mot de passe sécurisé."
               style="-fx-font-size: 13px; -fx-text-fill: #5a4a72;" wrapText="true" />

        <!-- New Password -->
        <VBox spacing="6" alignment="CENTER_LEFT">
            <Label text="Nouveau mot de passe" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" />
            <PasswordField fx:id="newPasswordField" promptText="Min 6 caractères, lettres + chiffres"
                           style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 12; -fx-font-size: 14px;" />
            <Label fx:id="strengthLabel" text="" style="-fx-font-size: 11px;" />
        </VBox>

        <!-- Confirm Password -->
        <VBox spacing="6" alignment="CENTER_LEFT">
            <Label text="Confirmer le mot de passe" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" />
            <PasswordField fx:id="confirmPasswordField" promptText="••••••••"
                           style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 12; -fx-font-size: 14px;" />
        </VBox>

        <!-- Message -->
        <Label fx:id="messageLabel" text="" style="-fx-font-size: 13px; -fx-font-weight: 600;" wrapText="true" />

        <!-- Reset button -->
        <Button text="Réinitialiser le mot de passe" mnemonicParsing="false" onAction="#handleReset" maxWidth="Infinity"
                style="-fx-background-color: linear-gradient(to right, #241197, #6c2a90); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 700; -fx-background-radius: 12; -fx-padding: 14 0; -fx-cursor: hand;" />

        <Hyperlink text="Annuler et se connecter" onAction="#handleCancel"
                   style="-fx-text-fill: #5a4a72; -fx-font-size: 13px; -fx-underline: false;" />
    </VBox>

    <Region VBox.vgrow="ALWAYS" />
</VBox>
