<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<VBox spacing="0.0" prefWidth="300.0" styleClass="card" stylesheets="@../theme.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.front.OeuvreIACardController">
    <StackPane styleClass="card-image-container" prefHeight="220.0" style="-fx-background-color: #f1f5f9; -fx-background-radius: 20 20 0 0;">
        <ImageView fx:id="oeuvreImage" fitHeight="220.0" fitWidth="300.0" preserveRatio="true" />
        <Label text="AI ✨" style="-fx-background-color: rgba(36, 17, 151, 0.9); -fx-text-fill: white; -fx-padding: 5 12; -fx-background-radius: 15; -fx-font-size: 10; -fx-font-weight: bold;" StackPane.alignment="TOP_LEFT">
            <StackPane.margin><Insets top="10" left="10"/></StackPane.margin>
        </Label>
    </StackPane>

    <VBox spacing="15.0" styleClass="card-content" style="-fx-padding: 20; -fx-background-color: white; -fx-background-radius: 0 0 20 20;">
        <VBox spacing="5.0">
            <Label fx:id="titreLabel" styleClass="card-title" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #1e293b;" wrapText="true" />
            <Label fx:id="categorieLabel" style="-fx-text-fill: #94a3b8; -fx-font-size: 13;" />
        </VBox>

        <Label fx:id="dateLabel" style="-fx-text-fill: #64748b; -fx-font-size: 11; -fx-font-style: italic;" />

        <HBox spacing="10.0" alignment="CENTER">
            <Button text="🗑 Supprimer" onAction="#handleDelete" style="-fx-background-color: #fee2e2; -fx-text-fill: #b91c1c; -fx-background-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;" />
            
            <Separator orientation="VERTICAL" prefHeight="20" />
            
            <HBox spacing="8" alignment="CENTER">
                <Button onAction="#shareFacebook" style="-fx-background-color: #1877F2; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-size: 10; -fx-font-weight: bold; -fx-cursor: hand;" text="f Partager" />
                <Button onAction="#shareTwitter" style="-fx-background-color: #000000; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-size: 10; -fx-font-weight: bold; -fx-cursor: hand;" text="𝕏 Tweet" />
            </HBox>
        </HBox>
    </VBox>
</VBox>
