<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="0" stylesheets="@../theme.css" styleClass="app-shell"
      prefHeight="800.0" prefWidth="1280.0"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.rouhfan.ui.front.ForgotPasswordController">

    <!-- Top bar -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="topbar">
        <padding>
            <Insets left="40.0" right="40.0" />
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <ImageView fitHeight="40.0" preserveRatio="true">
                <Image url="@../logo.png" />
            </ImageView>
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="← Retour" mnemonicParsing="false" styleClass="btn-secondary" onAction="#goLogin"
                style="-fx-background-radius: 20; -fx-font-weight: bold;" />
    </HBox>

    <Region VBox.vgrow="ALWAYS" />

    <!-- Forgot Password Card -->
    <VBox alignment="CENTER" spacing="20" maxWidth="440"
          style="-fx-background-color: #ffffff; -fx-background-radius: 24; -fx-padding: 50 40; -fx-effect: dropshadow(three-pass-box, rgba(36, 17, 151, 0.10), 20, 0, 0, 8);">

        <Label text="🔑" style="-fx-font-size: 48px;" />
        <Label text="Mot de passe oublié" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #241197;" />
        <Label text="Entrez votre adresse e-mail pour recevoir un code ou vérifiez via Google."
               style="-fx-font-size: 13px; -fx-text-fill: #5a4a72;" wrapText="true" />

        <!-- Email -->
        <VBox spacing="6" alignment="CENTER_LEFT">
            <Label text="Adresse e-mail" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" />
            <TextField fx:id="emailField" promptText="exemple@email.com"
                       style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 12; -fx-font-size: 14px;" />
        </VBox>

        <!-- Token field (hidden initially) -->
        <VBox fx:id="tokenBox" spacing="6" alignment="CENTER_LEFT" visible="false" managed="false">
            <Label text="Code de vérification (6 chiffres)" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" />
            <TextField fx:id="tokenField" promptText="000000"
                       style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 12; -fx-font-size: 18px; -fx-alignment: center; -fx-font-weight: bold;" />
        </VBox>

        <!-- Message -->
        <Label fx:id="messageLabel" text="" style="-fx-font-size: 13px; -fx-font-weight: 600;" wrapText="true" />

        <!-- Send / Verify button -->
        <Button fx:id="actionButton" text="Envoyer le code" mnemonicParsing="false" onAction="#handleAction" maxWidth="Infinity"
                style="-fx-background-color: linear-gradient(to right, #241197, #6c2a90); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 700; -fx-background-radius: 12; -fx-padding: 14 0; -fx-cursor: hand;" />

        <!-- Separator -->
        <HBox alignment="CENTER" spacing="10">
            <Separator HBox.hgrow="ALWAYS" />
            <Label text="ou" style="-fx-text-fill: #9b8fb5; -fx-font-size: 12px;" />
            <Separator HBox.hgrow="ALWAYS" />
        </HBox>

        <!-- Google Verify Button -->
        <Button fx:id="googleVerifyButton" text="🔴  Vérifier via Google" mnemonicParsing="false"
                onAction="#handleGoogleVerify" maxWidth="Infinity"
                style="-fx-background-color: #ffffff; -fx-border-color: #dadce0; -fx-border-width: 1.5; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 12 0; -fx-font-size: 14px; -fx-font-weight: 600; -fx-text-fill: #3c4043; -fx-cursor: hand;" />

        <!-- Login link -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="Vous vous souvenez ?" style="-fx-text-fill: #5a4a72; -fx-font-size: 13px;" />
            <Hyperlink text="Se connecter" onAction="#goLogin"
                       style="-fx-text-fill: #241197; -fx-font-weight: 700; -fx-font-size: 13px;" />
        </HBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS" />
</VBox>
