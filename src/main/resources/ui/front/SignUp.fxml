<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="0" stylesheets="@../theme.css" styleClass="app-shell"
      prefHeight="800.0" prefWidth="1280.0"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.rouhfan.ui.front.SignUpController">

    <!-- Top bar with back button -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="topbar">
        <padding>
            <Insets left="40.0" right="40.0" />
        </padding>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <ImageView fitHeight="40.0" preserveRatio="true">
                <Image url="@../logo.png" />
            </ImageView>
        </HBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="← Retour" mnemonicParsing="false" styleClass="btn-secondary" onAction="#goBack"
                style="-fx-background-radius: 20; -fx-font-weight: bold;" />
    </HBox>

    <!-- Spacer -->
    <Region VBox.vgrow="ALWAYS" />

    <!-- Sign Up Card -->
    <VBox alignment="CENTER" spacing="16" maxWidth="460"
          style="-fx-background-color: #ffffff; -fx-background-radius: 24; -fx-padding: 40 40; -fx-effect: dropshadow(three-pass-box, rgba(36, 17, 151, 0.10), 20, 0, 0, 8);">

        <Label text="✨" style="-fx-font-size: 42px;" />
        <Label text="Créer un compte" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #241197;" />
        <Label text="Rejoignez la communauté Rouh el Fann"
               style="-fx-font-size: 13px; -fx-text-fill: #5a4a72;" wrapText="true" />

        <!-- Nom + Prénom on same row -->
        <HBox spacing="12">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Nom" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" />
                <TextField fx:id="nomField" promptText="Votre nom"
                           style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 10; -fx-font-size: 13px;" />
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Prénom" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" />
                <TextField fx:id="prenomField" promptText="Votre prénom"
                           style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 10; -fx-font-size: 13px;" />
            </VBox>
        </HBox>

        <!-- Email -->
        <VBox spacing="6" alignment="CENTER_LEFT">
            <Label text="Adresse e-mail" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" />
            <TextField fx:id="emailField" promptText="exemple@email.com"
                       style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 10; -fx-font-size: 13px;" />
        </VBox>

        <!-- Type -->
        <VBox spacing="6" alignment="CENTER_LEFT">
            <Label text="Type de profil" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" />
            <ComboBox fx:id="typeCombo" promptText="Choisir un type" maxWidth="Infinity"
                      style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 4; -fx-font-size: 13px;" />
        </VBox>

        <!-- Password + Confirm on same row -->
        <HBox spacing="12">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Mot de passe" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" />
                <PasswordField fx:id="passwordField" promptText="••••••••"
                               style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 10; -fx-font-size: 13px;" />
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Confirmer" style="-fx-font-weight: 600; -fx-text-fill: #2d1b4e;" />
                <PasswordField fx:id="confirmPasswordField" promptText="••••••••"
                               style="-fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: rgba(36,17,151,0.15); -fx-padding: 10; -fx-font-size: 13px;" />
            </VBox>
        </HBox>

        <!-- Error label -->
        <Label fx:id="errorLabel" text="" style="-fx-text-fill: #d63031; -fx-font-size: 13px; -fx-font-weight: 600;" wrapText="true" />

        <!-- Register button -->
        <Button text="S'inscrire" mnemonicParsing="false" onAction="#handleSignUp" maxWidth="Infinity"
                style="-fx-background-color: linear-gradient(to right, #241197, #6c2a90); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: 700; -fx-background-radius: 12; -fx-padding: 14 0; -fx-cursor: hand;" />

        <!-- Login link -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="Déjà un compte ?" style="-fx-text-fill: #5a4a72; -fx-font-size: 13px;" />
            <Hyperlink text="Se connecter" onAction="#goLogin"
                       style="-fx-text-fill: #241197; -fx-font-weight: 700; -fx-font-size: 13px;" />
        </HBox>
    </VBox>

    <!-- Spacer -->
    <Region VBox.vgrow="ALWAYS" />
</VBox>