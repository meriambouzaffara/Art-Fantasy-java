<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.ProgressIndicator?>

<VBox prefWidth="800.0" prefHeight="700.0" spacing="0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.front.OeuvreStripePaymentDialogController" style="-fx-background-color: white;">
    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #241197; -fx-padding: 15;">
        <Label text="Paiement Sécurisé via Stripe" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16;" />
        <Region HBox.hgrow="ALWAYS" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" />
        <Button text="✕" onAction="#handleClose" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18; -fx-cursor: hand;" />
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        <WebView fx:id="webView" />
        
        <VBox fx:id="loadingOverlay" alignment="CENTER" spacing="15" style="-fx-background-color: white;">
            <ProgressIndicator prefWidth="50" prefHeight="50" />
            <Label text="Initialisation de la transaction sécurisée..." style="-fx-text-fill: #64748b;" />
        </VBox>

        <VBox fx:id="successContainer" alignment="CENTER" spacing="20" visible="false" managed="false" style="-fx-background-color: white; -fx-padding: 40;">
            <Label text="✅" style="-fx-font-size: 60;" />
            <Label text="Paiement Réussi !" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #15803d;" />
            <Label text="Votre achat a été confirmé. L'œuvre est désormais à vous." style="-fx-text-fill: #64748b; -fx-text-alignment: center;" />
            <Button text="Fermer" onAction="#handleCloseSuccess" style="-fx-background-color: #241197; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 30; -fx-background-radius: 5; -fx-cursor: hand;" />
        </VBox>
    </StackPane>
</VBox>
