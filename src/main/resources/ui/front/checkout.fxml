<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<VBox spacing="16.0"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.rouhfan.ui.front.CheckoutController"
      stylesheets="@../theme.css">
    <padding>
        <Insets top="20" right="22" bottom="22" left="22" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="2">
            <Label text="Checkout" styleClass="text-title" />
            <Label fx:id="cartCountLabel" text="0 article" styleClass="text-subtitle" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Vider le panier" onAction="#clearCart" styleClass="btn-secondary" />
    </HBox>

    <HBox spacing="18" VBox.vgrow="ALWAYS">
        <VBox spacing="12" prefWidth="420" minWidth="360"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16;
                     -fx-effect: dropshadow(three-pass-box, rgba(36,17,151,0.08), 12, 0, 0, 4);">
            <Label text="Votre panier"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #241197;" />
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox fx:id="cartItemsBox" spacing="10" />
            </ScrollPane>
            <Label fx:id="emptyCartLabel" text="Votre panier est vide."
                   visible="false" managed="false"
                   style="-fx-text-fill: #5a4a72; -fx-font-size: 13;" />
            <Label fx:id="totalLabel" text="Total: 0.00 DT"
                   style="-fx-font-size: 20; -fx-font-weight: 800; -fx-text-fill: #c9a849;" />
        </VBox>

        <VBox spacing="12" HBox.hgrow="ALWAYS"
              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 16;
                     -fx-effect: dropshadow(three-pass-box, rgba(36,17,151,0.08), 12, 0, 0, 4);">
            <Label text="Paiement Stripe et facture"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #241197;" />
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="emailField" promptText="Email pour recevoir la facture" HBox.hgrow="ALWAYS" />
                <Button fx:id="payButton" text="Payer avec Stripe" onAction="#startStripePayment" styleClass="btn-primary" />
                <Button fx:id="confirmButton" text="Confirmer et envoyer" onAction="#confirmPayment"
                        disable="true" styleClass="btn-gold" />
            </HBox>
            <Label fx:id="statusLabel" text="Chargez Stripe, finalisez le paiement, puis confirmez ici."
                   wrapText="true"
                   style="-fx-text-fill: #5a4a72; -fx-font-size: 12;" />
            <WebView fx:id="stripeWebView" minHeight="390" prefHeight="450" VBox.vgrow="ALWAYS"
                     style="-fx-border-color: rgba(36,17,151,0.14); -fx-border-radius: 12;" />
            <HBox spacing="12" alignment="CENTER_LEFT">
                <ImageView fx:id="qrPreview" fitWidth="96" fitHeight="96" preserveRatio="true"
                           visible="false" managed="false" />
                <Label fx:id="qrStatusLabel" text=""
                       wrapText="true"
                       style="-fx-text-fill: #241197; -fx-font-weight: bold;" />
            </HBox>
        </VBox>
    </HBox>
</VBox>
