<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.Line?>

<VBox spacing="0.0" prefWidth="1150.0" prefHeight="750.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.rouhfan.ui.front.OeuvreDetailsController" 
      style="-fx-background-color: white; -fx-background-radius: 40; -fx-border-color: #6d28d9; -fx-border-width: 4; -fx-border-radius: 40; -fx-padding: 3; -fx-effect: dropshadow(three-pass-box, rgba(109, 40, 217, 0.25), 60, 0, 0, 0);">
    <HBox spacing="0.0" VBox.vgrow="ALWAYS">
        <!-- Left Side: Image with Clip -->
        <StackPane prefWidth="480.0" style="-fx-background-color: #f5f3ff; -fx-background-radius: 35 0 0 35;">
            <ImageView fx:id="oeuvreImage" fitWidth="480.0" fitHeight="750.0" preserveRatio="true" smooth="true" />
            <VBox alignment="TOP_LEFT" pickOnBounds="false">
                <padding><Insets top="30" left="30"/></padding>
                <Label fx:id="statusBadge" style="-fx-background-color: linear-gradient(to right, #f59e0b, #d97706); -fx-text-fill: white; -fx-padding: 8 20; -fx-background-radius: 25; -fx-font-weight: 900; -fx-font-size: 11; -fx-text-transform: uppercase; -fx-effect: dropshadow(three-pass-box, rgba(217, 119, 6, 0.4), 15, 0, 0, 5);" />
            </VBox>
        </StackPane>

        <!-- Middle Side: Content -->
        <VBox spacing="30.0" prefWidth="420.0" style="-fx-padding: 50; -fx-background-color: white;">
            <VBox spacing="8.0">
                <Label fx:id="categorieLabel" style="-fx-text-fill: #d97706; -fx-font-weight: 900; -fx-font-size: 12; -fx-text-transform: uppercase; -fx-letter-spacing: 2;" />
                <Label fx:id="titreLabel" wrapText="true" style="-fx-text-fill: #4c1d95; -fx-font-size: 36; -fx-font-weight: 900; -fx-line-spacing: -2; -fx-font-family: 'Segoe UI Semibold';" />
            </VBox>

            <!-- Artist Card -->
            <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-background-color: #fdf4ff; -fx-padding: 15; -fx-background-radius: 20; -fx-border-color: #f5d0fe; -fx-border-width: 1;">
                <StackPane style="-fx-background-color: linear-gradient(to bottom right, #7c3aed, #db2777); -fx-background-radius: 50; -fx-min-width: 48; -fx-min-height: 48;">
                    <Label text="🎨" style="-fx-font-size: 18; -fx-text-fill: white;" />
                </StackPane>
                <VBox>
                    <Label text="ARTISTE CRÉATEUR" style="-fx-text-fill: #a21caf; -fx-font-size: 10; -fx-font-weight: 900; -fx-letter-spacing: 1;" />
                    <Label fx:id="artisteLabel" style="-fx-text-fill: #4c1d95; -fx-font-size: 16; -fx-font-weight: 800;" />
                </VBox>
            </HBox>

            <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                <Label text="DESCRIPTION DE L'ŒUVRE" style="-fx-text-fill: #6b7280; -fx-font-size: 10; -fx-font-weight: 900; -fx-letter-spacing: 1;" />
                <Label fx:id="descriptionLabel" wrapText="true" style="-fx-text-fill: #4b5563; -fx-font-size: 15; -fx-line-spacing: 6; -fx-font-family: 'Segoe UI';" />
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: #faf5ff; -fx-padding: 25; -fx-background-radius: 25; -fx-border-color: #f3e8ff; -fx-border-width: 1;">
                <Label text="VALEUR ESTIMÉE" style="-fx-text-fill: #7c3aed; -fx-font-size: 10; -fx-font-weight: 900; -fx-letter-spacing: 1;" />
                <Label fx:id="prixLabel" style="-fx-text-fill: #6d28d9; -fx-font-size: 32; -fx-font-weight: 900;" />
            </VBox>
        </VBox>

        <!-- Right Side: Comments -->
        <VBox prefWidth="400.0" style="-fx-background-color: #fdfaff; -fx-background-radius: 0 35 35 0; -fx-border-color: #f3e8ff; -fx-border-width: 0 0 0 1;">
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 25; -fx-border-color: #f3e8ff; -fx-border-width: 0 0 1 0;">
                <Label text="Commentaires" style="-fx-font-weight: 900; -fx-font-size: 18; -fx-text-fill: #4c1d95;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button text="✕" onAction="#close" style="-fx-background-color: #f3e8ff; -fx-text-fill: #7c3aed; -fx-font-size: 14; -fx-cursor: hand; -fx-background-radius: 50; -fx-min-width: 34; -fx-min-height: 34;" />
            </HBox>

            <ScrollPane fx:id="commentScrollPane" VBox.vgrow="ALWAYS" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-padding: 15;">
                <VBox fx:id="commentsVBox" spacing="20" />
            </ScrollPane>

            <VBox spacing="15" style="-fx-padding: 25; -fx-background-color: white; -fx-background-radius: 0 0 35 0; -fx-border-color: #f3e8ff; -fx-border-width: 1 0 0 0;">
                <Label fx:id="replyingToLabel" text="Répondre à..." visible="false" managed="false" style="-fx-text-fill: #d97706; -fx-font-size: 12; -fx-font-weight: bold;" />
                
                <VBox spacing="10" style="-fx-background-color: #faf5ff; -fx-background-radius: 20; -fx-padding: 12; -fx-border-color: #f3e8ff; -fx-border-width: 1; -fx-border-radius: 20;">
                    <TextArea fx:id="commentInput" promptText="Écrire un commentaire..." prefHeight="70" wrapText="true" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0; -fx-font-size: 14; -fx-font-family: 'Segoe UI';" />
                    <HBox alignment="CENTER_RIGHT" spacing="15">
                        <Button onAction="#showEmojiPicker" style="-fx-background-color: transparent; -fx-font-size: 20; -fx-cursor: hand; -fx-padding: 0;" text="😊" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button fx:id="cancelReplyBtn" text="Annuler" visible="false" managed="false" onAction="#cancelReply" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-weight: bold;" />
                        <Button text="Publier" onAction="#handlePostComment" style="-fx-background-color: linear-gradient(to right, #6d28d9, #db2777); -fx-text-fill: white; -fx-font-weight: 900; -fx-padding: 10 30; -fx-background-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(109, 40, 217, 0.2), 10, 0, 0, 4);" />
                    </HBox>
                </VBox>
            </VBox>
        </VBox>
    </HBox>

</VBox>
